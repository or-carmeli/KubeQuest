# Supabase project URL — found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon (public) key — found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Sentry — error monitoring (optional, production only)
# DSN — found in: Sentry dashboard → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=
# Environment label shown in Sentry (defaults to "production")
VITE_SENTRY_ENVIRONMENT=

# Sentry source map upload (CI only — not needed for local dev)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
